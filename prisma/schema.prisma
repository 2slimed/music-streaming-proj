// ---------------------------------------------------------------------------
// MelodyMix – Prisma Schema  (PostgreSQL)
// ---------------------------------------------------------------------------
// Architectural decisions
//   * Artists are NOT a separate table. The Track model stores `artists` as a
//     plain string (comma-separated) mirroring the Kaggle Spotify dataset.
//     A full many-to-many Artist <-> Track relation is out of scope for V1.
//   * The User model carries a `role` enum so the same table can represent
//     both regular listeners and artist profiles in the future.
//   * Tracks are sourced from the Kaggle dataset and enriched at runtime
//     via the Spotify Web API (preview URLs, cover art, etc.).  No audio
//     files are stored in cloud storage.
// ---------------------------------------------------------------------------

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---- Enums ----------------------------------------------------------------

enum UserRole {
  USER
  ARTIST
}

enum PlaylistPrivacy {
  PUBLIC
  PRIVATE
}

// ---- Auth.js required models ---------------------------------------------

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---- Core domain models ---------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          UserRole  @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts     Account[]
  sessions     Session[]
  playlists    Playlist[]
  libraryItems LibraryItem[]
  recentPlays  RecentPlay[]
  follows      UserFollows[] @relation("follower")
  followers    UserFollows[] @relation("following")
}

model Track {
  id           String  @id @default(cuid())
  trackId      String  @unique // original Spotify / dataset track_id
  artists      String  // comma-separated artist names from dataset
  albumName    String
  trackName    String

  // Raw values from the Kaggle Spotify dataset
  popularity   Int     @default(0)   // 0-100
  durationMs   Int     @default(0)
  explicit     Boolean @default(false)
  danceability Float   @default(0)   // already 0-1
  energy       Float   @default(0)   // already 0-1

  // Pre-normalized 0-1 feature vector for AI / cosine-similarity lookup.
  // Populated at seed / ingest time so queries never need runtime math.
  //   popularityNorm = popularity / 100
  //   durationMsNorm = clamp(durationMs / 600000, 0, 1)  (10 min cap)
  //   explicitNorm   = explicit ? 1.0 : 0.0
  //   danceabilityNorm & energyNorm mirror the raw values (already 0-1)
  popularityNorm   Float @default(0)
  durationMsNorm   Float @default(0)
  explicitNorm     Float @default(0)
  danceabilityNorm Float @default(0)
  energyNorm       Float @default(0)

  // External metadata (preview/cover resolved via Deezer API)
  externalId   String? @unique
  previewUrl   String?
  coverUrl     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  playlistTracks PlaylistTrack[]
  libraryItems   LibraryItem[]
  recentPlays    RecentPlay[]

  @@index([trackName])
  @@index([artists])
  @@index([albumName])
  @@index([popularity])
}

model Album {
  id       String @id @default(cuid())
  name     String
  artists  String // comma-separated
  coverUrl String?

  createdAt DateTime @default(now())

  @@index([name])
}

model Artist {
  id        String   @id @default(cuid())
  name      String   @unique
  bio       String?  @db.Text
  imageUrl  String?
  socials   String?  // JSON string: { "twitter": "...", "instagram": "..." }
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

model Playlist {
  id          String          @id @default(cuid())
  name        String
  description String?
  coverUrl    String?
  privacy     PlaylistPrivacy @default(PRIVATE)
  userId      String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  tracks PlaylistTrack[]

  @@index([userId])
  @@index([name])
}

model PlaylistTrack {
  id         String @id @default(cuid())
  playlistId String
  trackId    String
  position   Int    @default(0)

  addedAt DateTime @default(now())

  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  track    Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([playlistId, trackId])
  @@index([playlistId])
}

model UserFollows {
  id          String @id @default(cuid())
  followerId  String
  followingId String

  createdAt DateTime @default(now())

  follower  User @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model LibraryItem {
  id      String @id @default(cuid())
  userId  String
  trackId String

  addedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  track Track @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([userId, trackId])
  @@index([userId])
}

model RecentPlay {
  id      String @id @default(cuid())
  userId  String
  trackId String

  playedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  track Track @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@index([userId, playedAt(sort: Desc)])
  @@index([userId])
}
